---
permalink: "/math/"
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Math Reference — ECE Ref</title>
<link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
<nav>
  <div style="display:flex;align-items:center;gap:12px;padding:0 20px;height:48px;background:var(--bg1);border-bottom:1px solid var(--border)">
    <a class="nav-logo" href="/">ECE·REF</a>
    <span style="font-family:var(--font-mono);font-size:10px;color:var(--border2)">|</span>
    <span style="font-family:var(--font-mono);font-size:11px;color:var(--muted)">Math Reference</span>
  </div>
</nav>

<div class="launch-wrap">
  <div class="launch-eyebrow">∑ Not a layer — a tool you'll reference throughout</div>
  <div class="launch-title">Math Reference</div>
  <div class="launch-sub">Boolean algebra, number representation, and minimization techniques used across every layer of the stack. Linked in from wherever they're relevant.</div>

  <div class="math-grid">
    {% for topic in collections.mathTopics %}
    <a class="math-card" href="{{ topic.url }}">
      <div class="math-card-name">{{ topic.data.title }}</div>
      <div class="math-card-short">{{ topic.data.subtitle }}</div>
      <div class="math-card-status ready">ready</div>
    </a>
    {% endfor %}

    {% for stub in site.mathStubs %}
    <div class="math-card unbuilt" onclick="showToast('{{ stub.name }} — coming soon')">
      <div class="math-card-name">{{ stub.name }}</div>
      <div class="math-card-short">{{ stub.short }}</div>
      <div class="math-card-status soon">soon</div>
    </div>
    {% endfor %}
  </div>
</div>

<style>
.math-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; max-width: 900px; margin: 0 auto; }
.math-card { background: var(--bg1); border: 1px solid var(--border); border-radius: 14px; padding: 20px 20px 16px; text-decoration: none; transition: border-color .15s, background .15s, transform .12s; position: relative; overflow: hidden; display: block; cursor: pointer; }
.math-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--amber); opacity: .5; }
.math-card:hover { border-color: var(--border2); background: var(--bg2); transform: translateY(-2px); }
.math-card:hover::before { opacity: 1; }
.math-card-name { font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 5px; }
.math-card-short { font-size: 12px; color: var(--muted); line-height: 1.5; }
.math-card-status { display: inline-block; margin-top: 12px; font-family: var(--font-mono); font-size: 9px; padding: 3px 9px; border-radius: 5px; }
.math-card-status.ready { background: rgba(62,207,142,.12); color: var(--green); }
.math-card-status.soon { background: rgba(107,115,133,.12); color: var(--muted); }
</style>

<script src="/assets/js/site.js"></script>
</body>
</html>
